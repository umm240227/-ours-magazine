# Railway 블로그 엔진 서비스 환경변수 (Railway 대시보드 Variables에 설정 — .env 커밋 금지)

# ─ 필수 ─
ANTHROPIC_API_KEY=sk-ant-...        # claude -p 헤드리스 인증 (키체인/OAuth 대체, B1 해소)
GIT_PUSH_TOKEN=github_pat_...       # gono92 fine-grained PAT (repo=-ours-magazine, Contents Read/Write). git push origin main용

# ─ 선택 ─
SLACK_WEBHOOK_URL=https://hooks.slack.com/...   # 발행/실패 알림
MAX_BUDGET_USD=30                   # claude -p 1회 예산 캡 (기본 30)
GIT_AUTHOR_NAME=ours-magazine-bot
GIT_AUTHOR_EMAIL=bot@ours-magazine.jp

# ─ 자동 설정(Dockerfile) — 보통 건드릴 필요 없음 ─
# CHROME_BIN=/usr/bin/chromium
# PROJECT_ROOT=/app

# ─ Phase 3 후속(Semrush 붙일 때) ─
# SEMRUSH_API_KEY=...               # 자동 주제 발굴(create auto 무시드) 활성화 시
# GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET / GOOGLE_REFRESH_TOKEN  # 색인 제출(index-submit) 무인화
