<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  ours-magazine.jp 일일 자동 블로그 발행 — 한국(com.snshelp.daily-all.plist)과 동일 방식.
  ⚠️ 구독 모드: run-local.sh가 ANTHROPIC_API_KEY를 unset → Max 5x 구독으로 청구(API 종량제 아님).
  ⚠️ 이 plist엔 ANTHROPIC_API_KEY를 절대 넣지 않는다(넣으면 종량제로 돌아감).
  매일 08:00(로컬 시각) 1편 생성 → md-publish --commit → git push origin main → Vercel.
  전제: Mac 켜져 있고 사용자 GUI 로그인 상태(구독 토큰이 login 키체인에 있어 접근 필요).
  설치: bash script/cron/install-launchd.sh  (경로는 install 스크립트가 현재 머신에 맞게 치환)
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.ours-magazine.blog-daily</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>__PROJECT_ROOT__/script/cron/run-local.sh</string>
    </array>

    <key>WorkingDirectory</key>
    <string>__PROJECT_ROOT__</string>

    <!-- launchd는 환경이 빈약 → PATH/HOME 명시. ANTHROPIC_API_KEY는 의도적으로 없음(구독 청구). -->
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
        <key>HOME</key>
        <string>__HOME__</string>
        <key>LANG</key>
        <string>en_US.UTF-8</string>
    </dict>

    <!-- 매일 08:00 로컬 시각. 변경하려면 Hour/Minute 수정 후 재설치. -->
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>8</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>

    <!-- load 시 즉시 실행 안 함(우발적 발행 방지). 스케줄 시각에만 실행. -->
    <key>RunAtLoad</key>
    <false/>

    <!-- launchd 기본 fd 256 → claude CLI 즉사. run-local.sh도 ulimit로 올리지만 여기서도 보강. -->
    <key>SoftResourceLimits</key>
    <dict>
        <key>NumberOfFiles</key>
        <integer>65536</integer>
    </dict>

    <key>ProcessType</key>
    <string>Background</string>

    <key>StandardOutPath</key>
    <string>__PROJECT_ROOT__/tmp/local-logs/launchd-out.log</string>
    <key>StandardErrorPath</key>
    <string>__PROJECT_ROOT__/tmp/local-logs/launchd-err.log</string>
</dict>
</plist>
